@model ShipManagement.Models.Users.EditUserViewModel

<h1>Менижиране на потребители</h1>
<h4>Редактиране на потребител</h4>
<hr/>

<form asp-action="Edit" method="post">
    <div class="form-group">
        <label asp-for="Username">Потребителско име</label>
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="PhoneNumber">Телефонен номер</label>
        <input asp-for="PhoneNumber" class="form-control" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>
    
    <button type="submit" class="btn btn-primary">Запази</button>
</form>
