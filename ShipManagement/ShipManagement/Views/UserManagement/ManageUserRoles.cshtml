@model ShipManagement.Models.Roles.UserRolesViewModel

<h2>Manage Roles for @Model.Email</h2>

<form asp-action="ManageUserRoles" method="post">
    <input type="hidden" asp-for="Id" />
    <div>
        @for (int i = 0; i < Model.AllRoles.Count; i++)
        {
            <div class="form-check">
                <input class="form-check-input" type="radio" id="role_@i" name="SelectedRole" value="@Model.AllRoles[i].RoleName" @(Model.AllRoles[i].Selected ? "checked" : "") />
                <label class="form-check-label" for="role_@i">@Model.AllRoles[i].RoleName</label>
            </div>
        }
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>